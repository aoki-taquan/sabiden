# sabiden 環境変数ファイル例
# /etc/sabiden/sabiden.env に配置し、root:sabiden 0640 に設定すること:
#   sudo install -m 0640 -o root -g sabiden \
#       deploy/systemd/sabiden.env.example /etc/sabiden/sabiden.env
#
# 環境変数は config.toml の値を上書きする (config モジュール側のマージ規約に従う)。
# Secret はこのファイルにのみ書き、git にコミットしないこと。

# SIP REGISTER の認証パスワード (HGW 設定画面の "ユーザ認証パスワード" 等)
SABIDEN_SIP_PASSWORD=REPLACE_ME

# 内線 UAS の認証パスワード (内線アカウントごとに必要なら別途定義)
# SABIDEN_EXT_IPHONE_PASSWORD=REPLACE_ME
# SABIDEN_EXT_ANDROID_PASSWORD=REPLACE_ME

# ログレベル (trace/debug/info/warn/error)
SABIDEN_LOG_LEVEL=info

# Rust バックトレース (障害解析時のみ 1 / full)
# RUST_BACKTRACE=1
