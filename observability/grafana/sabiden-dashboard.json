{
  "title": "sabiden — NGN SIP B2BUA",
  "uid": "sabiden-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "tags": ["sabiden", "sip", "ngn"],
  "timezone": "",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": false,
          "text": "Prometheus",
          "value": "Prometheus"
        },
        "hide": 0,
        "refresh": 1,
        "regex": ""
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": {
          "query": "label_values(sabiden_sip_registered, instance)",
          "refId": "StandardVariableQuery"
        },
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "regex": "",
        "sort": 1
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "SIP Registered",
      "description": "sabiden_sip_registered: NGN への REGISTER 成功状態 (1 = 登録中、 0 = 未登録)。 0 が継続するなら NGN 認証 / DHCP option 120 / eth1 経路を確認。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "max(sabiden_sip_registered{instance=~\"$instance\"})",
          "legendFormat": "registered",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Active Calls",
      "description": "sabiden_call_active: 現在進行中の通話数 (B2BUA dialog 数)。 sabiden_extension_registered と併記。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(sabiden_call_active{instance=~\"$instance\"})",
          "legendFormat": "active calls"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(sabiden_extension_registered{instance=~\"$instance\"})",
          "legendFormat": "extensions"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "REGISTER success rate (5m)",
      "description": "rate(sabiden_sip_register_total{result=\"success\"}) / rate(total)。 1.0 = 全成功、 < 0.95 でアラート推奨。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.9
              },
              {
                "color": "green",
                "value": 0.99
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(sabiden_sip_register_total{result=\"success\",instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(sabiden_sip_register_total{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "success rate"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "INVITE answer rate (5m)",
      "description": "answered / (answered+busy+timeout+error) direction 別。 NGN outbound / extension / PWA outbound の 3 系統。 0.95 未満で要調査。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.8
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(sabiden_sip_invite_total{direction=\"ngn\",result=\"answered\",instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(sabiden_sip_invite_total{direction=\"ngn\",instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "ngn outbound"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(sabiden_sip_invite_total{direction=\"extension\",result=\"answered\",instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(sabiden_sip_invite_total{direction=\"extension\",instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "extension"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(sabiden_sip_invite_total{direction=\"pwa_outbound\",result=\"answered\",instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(sabiden_sip_invite_total{direction=\"pwa_outbound\",instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "pwa outbound"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "INVITE rate by direction × result",
      "description": "sabiden_sip_invite_total を direction × result で stacked rate 表示。 trend / 急増 / failure 偏りを観察。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (direction, result) (rate(sabiden_sip_invite_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{direction}} / {{result}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "NGN 5xx response rate",
      "description": "sabiden_ngn_5xx_total: NGN P-CSCF が返した 5xx を status 別 (500 / 503 / other) で観測 (RFC 3261 §21.5 / 3GPP TS 24.229 §5.2.7)。 carrier 障害 / parity allocator 退行 / DoS 等の早期検知。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "500"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "503"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (status) (rate(sabiden_ngn_5xx_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "NGN carrier retry outcome (Issue #260)",
      "description": "sabiden_ngn_carrier_retry_total: intermittent 5xx/486 に対する 1 回 retry の outcome 内訳 (RFC 3261 §20.33 / TTC JJ-90.24 §5.7.3)。 succeeded が出ているなら parity / port 起因の救済が効いている、 failed/aborted_by_cancel が増えるなら別系統。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (outcome) (rate(sabiden_ngn_carrier_retry_total{outcome!=\"not_retried\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Rate-limit rejected INVITE (TTC JJ-90.24 §5.7.1)",
      "description": "sabiden_sip_invite_blocked_by_rate_limit_total: 連続発信抑制で 503 拒否した outbound INVITE。 extension / pwa_outbound 別。 急増は loop / 自動発信 bug の兆候。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (direction) (rate(sabiden_sip_invite_blocked_by_rate_limit_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "RTP bridge throughput",
      "description": "sabiden_rtp_bridge_packets_total: B2BUA RTP リレーの方向別パケットレート (RFC 3550)。 8000 Hz / 20ms PCMU で 1 通話あたり ~50 pkt/s。 通話数 × 50 と整合するか確認。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "stacking": {
              "mode": "none"
            },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (direction) (rate(sabiden_rtp_bridge_packets_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Outbound INVITE interval (avg, seconds)",
      "description": "sabiden_sip_invite_interval_seconds_sum / _count による移動平均。 TTC JJ-90.24 §5.7.1 連続発信抑制の閾値より明らかに小さい値が続くなら loop / 自動発信が走っている可能性。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["mean", "min", "lastNotNull"]
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(sabiden_sip_invite_interval_seconds_sum{instance=~\"$instance\"}[5m])) / clamp_min(sum(rate(sabiden_sip_invite_interval_seconds_count{instance=~\"$instance\"}[5m])), 1e-9)",
          "legendFormat": "avg interval"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "RTP SSRC collisions / RTCP SR sent",
      "description": "sabiden_rtp_ssrc_collision_detected_total (RFC 3550 §8.2) と sabiden_rtcp_sr_sent_total (RFC 3550 §6.4.1 / RFC 5761 §3.3)。 collision が急増する場合は SSRC 採番 / 経路 mux 異常。 RTCP SR は通話品質計測の入力。",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(sabiden_rtp_ssrc_collision_detected_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "ssrc collisions"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(sabiden_rtcp_sr_sent_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "rtcp sr sent"
        }
      ]
    }
  ]
}
